generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS
// ============================================

enum RoundStatus {
  DRAFT
  LIVE
  FINISHED
}

enum VisibilityMode {
  OPEN
  BLIND
}

enum BlindRevealMode {
  REVEAL_AFTER_HOLE
  REVEAL_AFTER_ROUND
}

enum HoleEntryType {
  BLANK
  X
  VALUE
}

// ============================================
// PLAYER (Master list - not a user account)
// ============================================

model Player {
  id                     String   @id @default(cuid())
  fullName               String
  nickname               String?
  handicapIndex          Decimal? @db.Decimal(4, 1)
  handicapLastUpdatedAt  DateTime?
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  roundPlayers           RoundPlayer[]
  seasonStats            SeasonPlayerStat[]

  @@index([isActive])
}

// ============================================
// COURSE
// ============================================

model Course {
  id                 String   @id @default(cuid())
  name               String   @unique
  scorecardImageUrl  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  holes              CourseHole[]
  rounds             Round[]
}

model CourseHole {
  id           String @id @default(cuid())
  courseId     String
  holeNumber   Int    // 1-18
  par          Int
  handicapRank Int    // 1-18 (1 = hardest)

  course       Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, holeNumber])
  @@unique([courseId, handicapRank])
  @@index([courseId])
}

// ============================================
// FORMAT (Labels only - no scoring logic)
// ============================================

model Format {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rounds      Round[]
}

// ============================================
// ROUND
// ============================================

model Round {
  id               String          @id @default(cuid())
  name             String?         // Optional name for the round (e.g., "Week 1", "Championship")
  date             DateTime        @db.Date
  status           RoundStatus     @default(DRAFT)
  visibility       VisibilityMode  @default(OPEN)
  blindRevealMode  BlindRevealMode @default(REVEAL_AFTER_ROUND)
  buyInPerPlayer   Decimal         @default(30) @db.Decimal(10, 2)
  pot              Decimal?        @db.Decimal(10, 2)
  baseSkinValue    Decimal?        @db.Decimal(10, 2)
  startingHole     Int?            // 1 or 10
  teamSize         Int?
  teamMode         String?         // "RANDOM" or "BALANCED"

  // Tiebreaker info (when carryover skins resolved at end of round)
  tiebreakerTeamId    String?      // Team that won the tiebreaker (null if split)
  tiebreakerHoleNum   Int?         // Hole where tiebreaker was decided (null if split)
  tiebreakerSkinsWon  Int?         // Number of carryover skins won

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  courseId         String
  formatId         String

  course           Course          @relation(fields: [courseId], references: [id])
  format           Format          @relation(fields: [formatId], references: [id])
  teams            Team[]
  roundPlayers     RoundPlayer[]
  holeScores       HoleScore[]
  holeResults      HoleResult[]

  @@index([status])
  @@index([date])
}

// ============================================
// TEAM (Per round)
// ============================================

model Team {
  id              String   @id @default(cuid())
  roundId         String
  teamNumber      Int
  handicapTotal   Decimal? @db.Decimal(5, 1)
  totalPayout     Decimal  @default(0) @db.Decimal(10, 2)
  isTopPayingTeam Boolean  @default(false)
  finishedScoring Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  round           Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundPlayers    RoundPlayer[]
  holeScores      HoleScore[]

  @@unique([roundId, teamNumber])
  @@index([roundId])
}

// ============================================
// ROUND PLAYER (Links players to teams in rounds)
// ============================================

model RoundPlayer {
  id                  String   @id @default(cuid())
  roundId             String
  playerId            String
  teamId              String?
  payoutAmount        Decimal  @default(0) @db.Decimal(10, 2)
  wasOnTopPayingTeam  Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  round               Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  player              Player   @relation(fields: [playerId], references: [id])
  team                Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([roundId, playerId])
  @@index([roundId])
  @@index([playerId])
  @@index([teamId])
}

// ============================================
// HOLE SCORE (Per team per hole)
// ============================================

model HoleScore {
  id          String        @id @default(cuid())
  roundId     String
  teamId      String
  holeNumber  Int
  entryType   HoleEntryType @default(BLANK)
  value       Int?          // Only set when entryType = VALUE
  wasEdited   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  round       Round         @relation(fields: [roundId], references: [id], onDelete: Cascade)
  team        Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([roundId, teamId, holeNumber])
  @@index([roundId, holeNumber])
  @@index([teamId])
}

// ============================================
// HOLE RESULT (Computed per hole)
// ============================================

model HoleResult {
  id              String   @id @default(cuid())
  roundId         String
  holeNumber      Int
  winnerTeamId    String?  // null if tie
  isTie           Boolean  @default(false)
  carrySkinsUsed  Int      @default(1)
  holePayout      Decimal  @default(0) @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  round           Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([roundId, holeNumber])
  @@index([roundId])
}

// ============================================
// SEASON PLAYER STAT (Persisted year totals)
// ============================================

model SeasonPlayerStat {
  id                  String   @id @default(cuid())
  year                Int
  playerId            String
  totalWinnings       Decimal  @default(0) @db.Decimal(10, 2)
  totalBuyInsPaid     Decimal  @default(0) @db.Decimal(10, 2)
  roundsPlayed        Int      @default(0)
  topTeamAppearances  Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  player              Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([year, playerId])
  @@index([year])
  @@index([playerId])
}
